# --- Database ---
*.db
*.sqlite
*.sqlite3

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Node / Frontend ---
node_modules/
dist/
.cache/

# --- Logs ---
*.log
logs/

# --- Test coverage ---
.coverage
htmlcov/
.pytest_cache/
